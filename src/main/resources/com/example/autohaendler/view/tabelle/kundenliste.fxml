<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.autohaendler.controller.KundenListeController"
      style="-fx-background-color: #F0F2F5; -fx-padding: 20;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-padding: 0 0 16 0;">
        <Label text="Kundenliste (Betrieb ↔ Kunde)"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblStatus"
               style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
    </HBox>

    <!-- Hauptbereich -->
    <HBox spacing="10" style="-fx-padding: 0 0 10 0;">
        <ComboBox fx:id="cbFilterBetrieb" promptText="Alle Betriebe"/>
        <ComboBox fx:id="cbFilterKunde" promptText="Alle Kunden"/>
        <Button text="Reset" onAction="#handleFilterZuruecksetzen"/>
        <Label fx:id="lblAnzahl" text="Einträge: 0"/>
    </HBox>
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Tabelle -->
        <VBox HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);
                     -fx-padding: 16;">
            <TableView fx:id="tabelle" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colBetrieb"  text="Betrieb"  prefWidth="300"/>
                    <TableColumn fx:id="colKunde"    text="Kunde"    prefWidth="300"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Formular -->
        <VBox spacing="12" minWidth="240" maxWidth="260"
              style="-fx-background-color: white; -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);
                     -fx-padding: 20;">

            <Label text="Zuordnung erfassen"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #374151; -fx-padding: 0 0 4 0;"/>

            <VBox spacing="4">
                <Label text="Betrieb" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>
                <ComboBox fx:id="cbBetrieb" maxWidth="Infinity"
                          style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB;
                                 -fx-border-radius: 6; -fx-background-radius: 6;
                                 -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Kunde" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>
                <ComboBox fx:id="cbKunde" maxWidth="Infinity"
                          style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB;
                                 -fx-border-radius: 6; -fx-background-radius: 6;
                                 -fx-font-size: 13px;"/>
            </VBox>

            <VBox.margin><Insets top="8"/></VBox.margin>

            <!-- Buttons -->
            <GridPane hgap="8" vgap="8">
                <Button fx:id="btnHinzufuegen" text="＋ Hinzufügen"
                        onAction="#handleHinzufuegen" prefWidth="112"
                        style="-fx-background-color: #2563EB; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-background-radius: 7;
                               -fx-padding: 9 0 9 0; -fx-cursor: hand;"
                        GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Button text="↺ Leeren"
                        onAction="#handleLeeren" prefWidth="112"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #374151;
                               -fx-font-size: 12px; -fx-background-radius: 7;
                               -fx-padding: 9 0 9 0; -fx-cursor: hand;
                               -fx-border-color: #E5E7EB; -fx-border-radius: 7;"
                        GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Button fx:id="btnLoeschen" text="✕ Löschen"
                        onAction="#handleLoeschen" prefWidth="232"
                        style="-fx-background-color: #DC2626; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-background-radius: 7;
                               -fx-padding: 9 0 9 0; -fx-cursor: hand;"
                        GridPane.rowIndex="1" GridPane.columnIndex="0"
                        GridPane.columnSpan="2"/>
            </GridPane>

            <Button text="⬇ XML-Export" onAction="#handleXmlExport"
                    maxWidth="Infinity"
                    style="-fx-background-color: #FFF7ED; -fx-text-fill: #D97706;
                           -fx-font-size: 12px; -fx-font-weight: bold;
                           -fx-background-radius: 7; -fx-padding: 9 0 9 0;
                           -fx-cursor: hand; -fx-border-color: #FDE68A;
                           -fx-border-radius: 7;"/>
        </VBox>
    </HBox>
</VBox>
