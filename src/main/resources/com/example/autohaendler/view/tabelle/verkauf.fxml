<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" style="-fx-padding: 10;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.autohaendler.controller.VerkaufController">

    <Label text="Verkaufsverwaltung" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <TableView fx:id="tabelle" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNr"          text="Nr"          prefWidth="50"/>
            <TableColumn fx:id="colFahrzeug"    text="Fahrzeug"    prefWidth="160"/>
            <TableColumn fx:id="colKunde"       text="Kunde"       prefWidth="160"/>
            <TableColumn fx:id="colMitarbeiter" text="Mitarbeiter" prefWidth="160"/>
            <TableColumn fx:id="colDatum"       text="Datum"       prefWidth="100"/>
            <TableColumn fx:id="colPreis"       text="Preis (€)"   prefWidth="90"/>
        </columns>
    </TableView>

    <GridPane hgap="10" vgap="6">
        <Label text="Nr:"           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNr"    GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250"/>

        <Label text="Fahrzeug:"     GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbFahrzeug" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250"/>

        <Label text="Kunde:"        GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbKunde"   GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="250"/>

        <Label text="Mitarbeiter:"  GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbMitarbeiter" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="250"/>

        <Label text="Datum:"        GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpDatum" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Preis (€):"    GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPreis" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10">
        <Button fx:id="btnHinzufuegen" text="Hinzufügen" onAction="#handleHinzufuegen"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button fx:id="btnAendern"     text="Ändern"     onAction="#handleAendern"
                style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button fx:id="btnLoeschen"    text="Löschen"    onAction="#handleLoeschen"
                style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="Leeren" onAction="#handleLeeren"/>
    </HBox>

    <Label fx:id="lblStatus" style="-fx-text-fill: #555;"/>
</VBox>
