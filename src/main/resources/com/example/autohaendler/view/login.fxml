<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.autohaendler.controller.LoginController"
            prefWidth="480" prefHeight="360"
            style="-fx-background-color: #F0F2F5;">

    <VBox alignment="CENTER" spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Card -->
        <VBox alignment="CENTER" spacing="16"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 20, 0, 0, 4);
                     -fx-padding: 48 52 48 52;
                     -fx-max-width: 360;">

            <!-- Logo-Bereich -->
            <Label text="🚗"
                   style="-fx-font-size: 36px;"/>
            <Label text="Händler Verwaltungssystem"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-text-fill: #1A1A2E;"/>
            <Label text="Bitte melden Sie sich an"
                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280;
                          -fx-padding: 0 0 8 0;"/>

            <!-- Felder -->
            <VBox spacing="6" maxWidth="280">
                <Label text="Benutzername"
                       style="-fx-font-size: 12px; -fx-font-weight: bold;
                              -fx-text-fill: #374151;"/>
                <TextField fx:id="txtBenutzername"
                           promptText="Benutzername eingeben"
                           style="-fx-background-color: #F9FAFB;
                                  -fx-border-color: #D1D5DB;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14 10 14;
                                  -fx-font-size: 13px; -fx-text-fill: #111827;
                                  -fx-pref-width: 280;"/>
            </VBox>

            <VBox spacing="6" maxWidth="280">
                <Label text="Passwort"
                       style="-fx-font-size: 12px; -fx-font-weight: bold;
                              -fx-text-fill: #374151;"/>
                <PasswordField fx:id="txtPasswort"
                               promptText="Passwort eingeben"
                               style="-fx-background-color: #F9FAFB;
                                      -fx-border-color: #D1D5DB;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-padding: 10 14 10 14;
                                      -fx-font-size: 13px;
                                      -fx-pref-width: 280;"/>
            </VBox>

            <Label fx:id="lblFehler"
                   style="-fx-text-fill: #DC2626; -fx-font-size: 12px;"
                   maxWidth="280"/>

            <Button fx:id="btnLogin" text="Einloggen"
                    onAction="#handleLogin"
                    prefWidth="280" prefHeight="40"
                    style="-fx-background-color: #2563EB; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.35), 8, 0, 0, 2);"/>
        </VBox>
    </VBox>
</AnchorPane>
